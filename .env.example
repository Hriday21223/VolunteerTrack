# Email backend (used by POST /api/send-reset-email for password & PIN recovery).
# Leave these unset to run in "code on screen" mode — the recovery code is
# displayed locally but no email is sent. Set them to actually deliver mail.

# SMTP host, e.g. smtp.gmail.com, smtp.resend.com, smtp.sendgrid.net
EMAIL_HOST=

# SMTP port (587 for STARTTLS, 465 for implicit TLS)
EMAIL_PORT=587

# true => implicit TLS (port 465). false/unset => STARTTLS.
EMAIL_SECURE=false

# SMTP credentials
EMAIL_USER=
EMAIL_PASSWORD=

# Optional "From" address; falls back to EMAIL_USER
EMAIL_FROM=
