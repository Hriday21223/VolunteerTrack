# Email backend (used by POST /api/send-reset-email for password & PIN recovery).
# Leave these unset to run in "code on screen" mode — the recovery code is
# displayed locally but no email is sent. Set them to actually deliver mail.

# SMTP host, e.g. smtp.gmail.com, smtp.resend.com, smtp.sendgrid.net
EMAIL_HOST=smtp.gmail.com

# SMTP port (587 for STARTTLS, 465 for implicit TLS)
EMAIL_PORT=587

# true => implicit TLS (port 465). false/unset => STARTTLS.
EMAIL_SECURE=false

# SMTP credentials
EMAIL_USER=your-account@example.com
EMAIL_PASSWORD=your-smtp-app-password


# Optional "From" address; falls back to EMAIL_USER
EMAIL_FROM=volunteertrack@googlegroups.com


# ----- Server-backed accounts & school dashboards -----
# Postgres connection string. When unset, the server runs in email-only mode
# (no accounts API). On Render/Neon this is provided by the managed database.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Set to "disable" to turn off TLS for the DB connection (local dev only).
# Managed Postgres requires TLS, so leave this unset in production.
# PGSSL=disable

# Secret used to sign JWT auth tokens. REQUIRED in production — generate a long
# random value, e.g. `node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"`.
# JWT_SECRET=change-me-to-a-long-random-string

# Optional admin account seeded on boot (created only if it does not exist).
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=choose-a-strong-password

# Frontend API URL (for production deployment)
# VITE_API_URL=https://your-backend-url.onrender.com
